# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
tfplan.binary
crash.log
crash.*.log
*.auto.tfvars
*.auto.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Never commit real secrets
secrets.tfvars

# Local backups produced by scripts/backup.sh
backups/*.sql
!backups/.gitkeep

# OS/editor cruft
.DS_Store
*.swp
